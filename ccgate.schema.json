{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "API timeout in milliseconds. 0 means no timeout. Default: 20000"
        }
      }
    },
    "allow": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deny": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "log_path": {
      "type": "string",
      "description": "Log file path. Supports ~ for home directory. Default: $XDG_STATE_HOME/ccgate/ccgate.log"
    },
    "log_disabled": {
      "type": "boolean",
      "description": "Disable logging entirely. Default: false"
    },
    "log_max_size": {
      "type": "integer",
      "minimum": 0,
      "description": "Max log file size in bytes before rotation. Default: 5242880 (5MB)"
    },
    "metrics_path": {
      "type": "string",
      "description": "Metrics JSONL file path. Default: $XDG_STATE_HOME/ccgate/metrics.jsonl"
    },
    "metrics_disabled": {
      "type": "boolean",
      "description": "Disable metrics collection. Default: false"
    },
    "metrics_max_size": {
      "type": "integer",
      "minimum": 0,
      "description": "Max metrics file size in bytes before rotation. Default: 2097152 (2MB)"
    },
    "environment": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
